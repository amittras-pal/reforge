    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "^3.20.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.7.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@tabler/icons-svelte": "^3.44.0",
